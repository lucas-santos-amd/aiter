#include "sampling.cuh"


#define FUNCTION_DEFINE                                      \
    void {{func_name}}(void* probs_ptr,                      \
                      void* renormed_probs_ptr,              \
                      void* top_k_arr_ptr,                   \
                      int batch_size,                        \
                      int top_k_val,                         \
                      int vocab_size,                        \
                      void* stream)

extern "C" {
FUNCTION_DEFINE;
}

FUNCTION_DEFINE
{
    aiter::sampling::topk_renorm_from_probs(
        reinterpret_cast<float*>(probs_ptr),
        reinterpret_cast<float*>(renormed_probs_ptr),
        reinterpret_cast<int*>(top_k_arr_ptr),
        batch_size, top_k_val, vocab_size,
        reinterpret_cast<hipStream_t>(stream));
}